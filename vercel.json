{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile --ignore-scripts",
  "buildCommand": "echo 'serverless functions only; no build step'",
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/api/index" }],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  }
}
