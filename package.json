{
  "name": "socrm",
  "version": "0.0.1",
  "private": true,
  "description": "Solo Agentic CRM — multi-tenant CRM for solopreneurs and their agents",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "build": "tsdown",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "bin": {
    "socrm": "./dist/cli/main.js",
    "socrm-mcp": "./dist/mcp/server.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@libsql/client": "^0.14.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.1.0",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "pino": "^9.5.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "pino-pretty": "^13.0.0",
    "tsdown": "^0.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
