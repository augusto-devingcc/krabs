{
  "name": "krabs",
  "version": "0.5.0",
  "private": true,
  "description": "krabs.dev — a CRM designed to be operated by AI agents. Reachable over MCP, CLI, or HTTP. Every mutation is idempotent, dry-runnable, and reversible.",
  "license": "MIT",
  "homepage": "https://krabs.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/augusto-devingcc/krabs.git"
  },
  "bugs": {
    "url": "https://github.com/augusto-devingcc/krabs/issues"
  },
  "keywords": [
    "crm",
    "agent",
    "ai-agent",
    "mcp",
    "model-context-protocol",
    "claude",
    "openclaw",
    "self-hosted",
    "next.js",
    "hono",
    "drizzle",
    "turso"
  ],
  "author": "Augusto García <augusto@realtialabs.com>",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:api": "tsx watch src/api/server.ts",
    "build": "next build --webpack",
    "start": "next start",
    "build:cli": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "setup": "tsx src/scripts/setup.ts",
    "kickoff": "tsdown && tsx src/scripts/setup.ts",
    "db:studio": "drizzle-kit studio"
  },
  "bin": {
    "krabs": "./dist/cli/main.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@clerk/nextjs": "^7.3.4",
    "@hono/node-server": "^1.13.7",
    "@hugeicons/core-free-icons": "^4.1.4",
    "@hugeicons/react": "^1.1.6",
    "@libsql/client": "^0.14.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^12.1.0",
    "drizzle-orm": "^0.36.4",
    "geist": "^1.7.0",
    "hono": "^4.6.14",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "pino": "^9.5.0",
    "postcss": "^8.5.14",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^6.12.3",
    "shadcn": "^4.7.0",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "pino-pretty": "^13.0.0",
    "tsdown": "^0.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "@clerk/shared",
      "msw"
    ]
  }
}
