{
  "name": "socrm",
  "version": "0.0.1",
  "private": true,
  "description": "Solo Agentic CRM — multi-tenant CRM for solopreneurs and their agents",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:api": "tsx watch src/api/server.ts",
    "build": "next build --webpack",
    "start": "next start",
    "build:cli": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "bin": {
    "socrm": "./dist/cli/main.js",
    "socrm-mcp": "./dist/mcp/server.js"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.3.4",
    "@hono/node-server": "^1.13.7",
    "@libsql/client": "^0.14.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@tailwindcss/postcss": "^4.3.0",
    "commander": "^12.1.0",
    "drizzle-orm": "^0.36.4",
    "geist": "^1.7.0",
    "hono": "^4.6.14",
    "next": "^16.2.6",
    "pino": "^9.5.0",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "pino-pretty": "^13.0.0",
    "tsdown": "^0.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "@clerk/shared"
    ]
  }
}
