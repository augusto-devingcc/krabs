{
  "name": "krabs",
  "version": "0.6.0",
  "private": true,
  "description": "krabs — a personal finance tracker (income / expenses / cashflow) designed to be operated by AI agents. Reachable over MCP, CLI, or HTTP. Every mutation is idempotent, dry-runnable, and reversible. Self-host, no login, no dashboard.",
  "license": "MIT",
  "homepage": "https://krabs.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/augusto-devingcc/krabs.git"
  },
  "bugs": {
    "url": "https://github.com/augusto-devingcc/krabs/issues"
  },
  "keywords": [
    "finance",
    "cashflow",
    "expenses",
    "mrr",
    "agent",
    "ai-agent",
    "mcp",
    "model-context-protocol",
    "claude",
    "self-hosted",
    "hono",
    "drizzle"
  ],
  "author": "Augusto García <augusto@realtialabs.com>",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:api": "tsx watch src/api/server.ts",
    "build:cli": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "setup": "tsx src/scripts/setup.ts",
    "kickoff": "tsdown && tsx src/scripts/setup.ts",
    "db:studio": "drizzle-kit studio"
  },
  "bin": {
    "krabs": "./dist/cli/main.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@libsql/client": "^0.14.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.1.0",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "pino": "^9.5.0",
    "stripe": "^22.2.1",
    "ulid": "^2.3.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "pino-pretty": "^13.0.0",
    "tsdown": "^0.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
