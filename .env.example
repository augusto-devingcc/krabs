# krabs.dev — example environment file
#
# Quickstart
# ──────────
# For self-host / local dev: copy this file to .env, leave DATABASE_URL as the
# default `file:./data/local.db`, leave the CLERK_* / TURSO_* vars commented
# out, then run `pnpm setup`.
#
# For hosted deployment: fill in the CLERK_* and TURSO_* sections.
#
# Copy this file to `.env` and fill in the values you need for your mode:
#   - dev          → only Core + Database are required (the rest are optional)
#   - self-host    → Core + Database; Clerk only if you mount the web dashboard
#   - hosted       → Core + Turso (Vercel Marketplace) + Clerk
#
# Every variable below is actually consumed by the codebase. If a variable is
# only relevant to a specific mode, it says so in the comment.

# ──────────────────────────────────────────────────────────────
# Core
# ──────────────────────────────────────────────────────────────

# Node environment. `development` enables verbose logs and dev-only routes.
NODE_ENV=development

# HTTP port for the standalone Hono API (`pnpm dev:api`). The Next.js app
# uses its own default (3000) which can be overridden with `next dev -p`.
PORT=3000

# Log level for pino. One of: trace | debug | info | warn | error | fatal.
LOG_LEVEL=info

# ──────────────────────────────────────────────────────────────
# Database (libSQL / SQLite-compatible)
# ──────────────────────────────────────────────────────────────
# Local dev points at a file URL. Hosted deployments override this with the
# Turso credentials below (which take precedence over DATABASE_URL).
# See: https://docs.turso.tech/quickstart

# Primary database URL. Use `file:./data/local.db` for local dev, or a
# `libsql://…` URL for a remote database.
DATABASE_URL=file:./data/local.db

# Auth token for DATABASE_URL when it's a remote libSQL endpoint. Leave
# unset when using a local file: URL.
# DATABASE_AUTH_TOKEN=

# Optional — Turso integration on Vercel Marketplace auto-provisions these
# and they take precedence over DATABASE_URL / DATABASE_AUTH_TOKEN.
# See: https://vercel.com/marketplace/turso
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

# ──────────────────────────────────────────────────────────────
# Authentication — Clerk
# ──────────────────────────────────────────────────────────────
# Required for the hosted web dashboard (`app/`). Self-host installs that
# only expose the HTTP/MCP API can omit these.
# Get keys at: https://dashboard.clerk.com

# Server-side Clerk secret (read by @clerk/nextjs middleware/server helpers).
CLERK_SECRET_KEY=

# Public Clerk publishable key (consumed by the Clerk SDK in the browser).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Redirect paths used by Clerk's hosted sign-in / sign-up components.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ──────────────────────────────────────────────────────────────
# MCP server — outbound API credentials
# ──────────────────────────────────────────────────────────────
# The MCP server in `src/mcp/server.ts` is a thin proxy to a running krabs
# HTTP API. These are the credentials it uses to talk to that API.

# API key the MCP server uses to authenticate against the krabs HTTP API.
# Required when running the MCP server.
SOCRM_API_KEY=

# Base URL of the krabs HTTP API that the MCP server talks to.
# Defaults to the hosted endpoint if unset.
# SOCRM_API_URL=https://api.krabs.dev

# ──────────────────────────────────────────────────────────────
# CLI — client credentials
# ──────────────────────────────────────────────────────────────
# Consumed by `src/cli/config.ts`. The CLI also reads from a config file
# (under $XDG_CONFIG_HOME/krabs or ~/.config/krabs); env vars take precedence.

# API key for the krabs CLI. Set this or run `krabs auth login`.
# KRABS_API_KEY=

# Base URL the CLI talks to. Defaults to the hosted endpoint.
# KRABS_API_URL=https://api.krabs.dev

# Optional — XDG config directory override (POSIX). Falls back to
# `$HOME/.config` when unset. Only relevant to the CLI.
# XDG_CONFIG_HOME=

# ──────────────────────────────────────────────────────────────
# Integrations (Phase B)
# ──────────────────────────────────────────────────────────────

# 32-byte encryption key for storing per-account integration secrets
# (Stripe restricted API keys, webhook secrets, etc.) at rest.
# Generate once with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# REQUIRED in production. Dev falls back to a non-secure derived key.
# KRABS_CRED_ENCRYPTION_KEY=

# Stripe — for krabs.dev's OWN platform billing (the SaaS we charge users for).
# Unrelated to user-tenant Stripe credentials, which are stored per-account in
# the `integrations` table after each user connects via the dashboard.
# KRABS_STRIPE_SECRET_KEY=
# KRABS_STRIPE_PLATFORM_WEBHOOK_SECRET=

# ──────────────────────────────────────────────────────────────
# Required-vars cheat sheet
# ──────────────────────────────────────────────────────────────
# dev          → NODE_ENV, PORT, LOG_LEVEL, DATABASE_URL
# self-host    → above + (DATABASE_AUTH_TOKEN or TURSO_* if remote DB);
#                add SOCRM_API_KEY/SOCRM_API_URL if running the MCP server;
#                add CLERK_*/NEXT_PUBLIC_CLERK_* only if mounting the web app
# hosted       → NODE_ENV, LOG_LEVEL, TURSO_DATABASE_URL, TURSO_AUTH_TOKEN,
#                CLERK_SECRET_KEY, NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY,
#                NEXT_PUBLIC_CLERK_SIGN_IN_URL, NEXT_PUBLIC_CLERK_SIGN_UP_URL,
#                NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL,
#                NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL
# CLI users    → KRABS_API_KEY, KRABS_API_URL
