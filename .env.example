# krabs — personal finance tracker for AI agents (self-host, no login, no dashboard).
# Copy to .env.local and adjust. `pnpm setup` bootstraps the DB + a single API key.

# ── Database ────────────────────────────────────────────────────────
# Local single-user mode (default). libSQL file URL.
DATABASE_URL=file:./data/local.db

# Optional remote libSQL / Turso target. Leave blank for local file mode.
# DATABASE_AUTH_TOKEN=

# ── API ─────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# ── Stripe webhook (optional) ────────────────────────────────────────
# Set both to enable Stripe → krabs income import.
# KRABS_STRIPE_SECRET_KEY=sk_live_...
# KRABS_STRIPE_WEBHOOK_SECRET=whsec_...
